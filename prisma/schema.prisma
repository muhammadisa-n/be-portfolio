generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
  output        = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         String    @id @default(uuid())
  fullName   String    @db.VarChar(100)
  email      String    @unique @db.VarChar(100)
  password   String    @db.VarChar(255)
  image_id   String?   @db.VarChar(200)
  image_url  String?   @db.VarChar(300)
  created_at DateTime  @default(now()) @db.Timestamp(0)
  updated_at DateTime  @updatedAt @db.Timestamp(0)
  deleted_at DateTime? @db.Timestamp(0)

  @@map("users")
}

enum ToolType {
  language
  runtime
  framework
  database
  tools
}

model Tool {
  id               Int              @id @default(autoincrement())
  name             String           @db.VarChar(100)
  description      String           @db.VarChar(100)
  image_id         String           @db.VarChar(200)
  image_url        String           @db.VarChar(300)
  tool_url         String           @db.VarChar(100)
  type             ToolType?
  sort_order       Int?             @default(0)
  show             Boolean?         @default(true)
  created_at       DateTime         @default(now()) @db.Timestamp(0)
  updated_at       DateTime         @updatedAt @db.Timestamp(0)
  deleted_at       DateTime?        @db.Timestamp(0)
  project_has_tool ProjectHasTool[]

  @@map("tools")
}

model Project {
  id               Int              @id @default(autoincrement())
  name             String           @db.VarChar(100)
  description      String           @db.Text()
  demo_url         String           @db.VarChar(100)
  project_url      String           @db.VarChar(100)
  created_at       DateTime         @default(now()) @db.Timestamp(0)
  updated_at       DateTime         @updatedAt @db.Timestamp(0)
  deleted_at       DateTime?        @db.Timestamp(0)
  project_has_tool ProjectHasTool[]
  images           ProjectImage[]

  @@map("projects")
}

model ProjectHasTool {
  project_id Int
  tool_id    Int
  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  tool       Tool    @relation(fields: [tool_id], references: [id], onDelete: Cascade)

  @@unique([project_id, tool_id])
  @@map("project_has_tools")
}

model ProjectImage {
  id         Int      @id @default(autoincrement())
  project_id Int
  image_id   String   @db.VarChar(200)
  image_url  String   @db.VarChar(300)
  sort_order Int?     @default(0)
  created_at DateTime @default(now()) @db.Timestamp(0)

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("project_images")
}

model Message {
  id         String    @id @default(uuid())
  fullName   String    @db.VarChar(100)
  email      String    @db.VarChar(255)
  message    String    @db.Text()
  created_at DateTime  @default(now()) @db.Timestamp(0)
  updated_at DateTime  @updatedAt @db.Timestamp(0)
  deleted_at DateTime? @db.Timestamp(0)

  @@map("messages")
}

model Translation {
  id       Int    @id @default(autoincrement())
  language String @db.VarChar(100)
  key      String @db.VarChar(100)
  value    String @db.Text()

  @@unique([language, key], name: "language_key")
  @@map("translations")
}

enum FileVersion {
  INDONESIA
  ENGLISH
}

enum Type {
  CV_RESUME
  HERO_IMAGE
}

model File {
  id         Int          @id @default(autoincrement())
  filename   String       @db.VarChar(100)
  file_id    String       @db.VarChar(100)
  file_url   String       @db.VarChar(300)
  mimetype   String       @db.VarChar(300)
  version    FileVersion? @unique
  type       Type?
  created_at DateTime     @default(now()) @db.Timestamp(0)
  updated_at DateTime     @updatedAt @db.Timestamp(0)
  deleted_at DateTime?    @db.Timestamp(0)

  @@map("files")
}

enum TrashEntityType {
  user
  tool
  project
  message
  file
}

model TrashLog {
  id          Int             @id @default(autoincrement())
  entity_id   String          @db.VarChar(100)
  entity_type TrashEntityType
  title       String          @db.VarChar(150)
  subtitle    String?         @db.VarChar(255)
  image_url   String?         @db.VarChar(300)
  deleted_at  DateTime        @default(now()) @db.Timestamp(0)

  @@unique([entity_id, entity_type])
  @@map("trash_logs")
}
